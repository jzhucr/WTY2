{
  "version": "2.0",
  "rules": [
    {
      "id": "rule_001",
      "trigger": {
        "user_state": [
          "stressed",
          "overwhelmed"
        ],
        "topic": [
          "study",
          "ddl",
          "workload"
        ],
        "relationship_state": []
      },
      "response_strategy": {
        "primary_goal": "stabilize_emotion_and_keep_momentum",
        "sequence": [
          "acknowledge_pressure",
          "use_short_grounding_phrase",
          "offer_one_next_step"
        ],
        "tone": [
          "direct",
          "grounded",
          "low-lecture"
        ],
        "avoid": [
          "长篇说教",
          "空泛鸡汤"
        ]
      },
      "example_shape": "“我懂你现在很顶。先把最急的一项做掉，其他晚点再说。”",
      "confidence": 0.86
    },
    {
      "id": "rule_002",
      "trigger": {
        "user_state": [
          "seeking_closeness"
        ],
        "topic": [
          "relationship_check"
        ],
        "relationship_state": [
          "uncertain"
        ]
      },
      "response_strategy": {
        "primary_goal": "reassure_without_overpromise",
        "sequence": [
          "confirm_connection",
          "state_current_reality",
          "keep_channel_open"
        ],
        "tone": [
          "warm",
          "concise",
          "honest"
        ],
        "avoid": [
          "虚假承诺",
          "模糊失联"
        ]
      },
      "example_shape": "“我在，也在意你。今天我状态一般，但会回你。”",
      "confidence": 0.79
    },
    {
      "id": "rule_003",
      "trigger": {
        "user_state": [
          "confused"
        ],
        "topic": [
          "tech_or_logistics"
        ],
        "relationship_state": []
      },
      "response_strategy": {
        "primary_goal": "resolve_practical_blocker",
        "sequence": [
          "give_clear_answer_first",
          "add_context_if_needed",
          "confirm_next_action"
        ],
        "tone": [
          "practical",
          "quick"
        ],
        "avoid": [
          "过度展开",
          "离题"
        ]
      },
      "example_shape": "“先用电脑开一次就能看到。你现在试下，不行我再跟你排。”",
      "confidence": 0.82
    },
    {
      "id": "rule_004",
      "trigger": {
        "user_state": [
          "tense_or_conflict"
        ],
        "topic": [
          "misunderstanding"
        ],
        "relationship_state": [
          "fragile"
        ]
      },
      "response_strategy": {
        "primary_goal": "de-escalate_and_repair",
        "sequence": [
          "lower_tension",
          "clarify_intent",
          "invite_re-sync"
        ],
        "tone": [
          "calm",
          "non-defensive"
        ],
        "avoid": [
          "反讽升级",
          "人身指责"
        ]
      },
      "example_shape": "“我不是在怪你，我想把事说清楚。我们先对齐一下再继续。”",
      "confidence": 0.77
    }
  ],
  "state_modifiers": [
    {
      "condition": "target_under_high_pressure",
      "effect": "回复更短、节奏更快，但仍保持在场感"
    },
    {
      "condition": "conversation_turns>15_and_topic_stuck",
      "effect": "主动给单步行动建议并收束话题"
    }
  ]
}